# ─── FACTION — Environment Variables ─────────────────────────────────────────
# Copy this file to .env.local for local development.
# In Vercel, add these under Project → Settings → Environment Variables.

# ─── Required ─────────────────────────────────────────────────────────────────

# Your deployment URL, no trailing slash.
# Used for Open Graph images, canonical links, and sitemap.
# Local dev: http://localhost:3000
# Production: https://your-project.vercel.app  (or your custom domain)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Recommended for production ───────────────────────────────────────────────

# Secret that protects the /api/cron/check-links endpoint.
# Vercel automatically sends this as `Authorization: Bearer <value>`
# on every cron invocation.
# Generate a strong random value:   openssl rand -base64 32
CRON_SECRET=

# ─── Optional — Vercel KV (persistent link-health cache) ─────────────────────
# If you add a Vercel KV store to this project, fill in the values below
# and update src/lib/content.ts to use KV instead of the filesystem.
# See DEPLOYMENT.md for step-by-step instructions.
#
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
